<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_utama">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/btn_reviews"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <!-- Backdrop Frame -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="280dp">

                <ImageView
                    android:id="@+id/iv_backdrop"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:contentDescription="Movie Backdrop" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:layout_gravity="bottom"
                    android:background="@drawable/bottom_gradient" />
            </FrameLayout>

            <!-- Movie Information Body -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:layout_marginTop="-20dp">

                <TextView
                    android:id="@+id/tv_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Movie Title"
                    android:textColor="@color/teks_utama"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <!-- Meta row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="8dp">

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@android:drawable/btn_star_big_on"
                        app:tint="@color/aksen_amber" />

                    <TextView
                        android:id="@+id/tv_rating"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="8.5 / 10"
                        android:textColor="@color/aksen_amber"
                        android:textSize="12sp"
                        android:layout_marginStart="4dp"
                        android:textStyle="bold" />

                    <View
                        android:layout_width="1dp"
                        android:layout_height="12dp"
                        android:background="@color/teks_nonaktif"
                        android:layout_marginHorizontal="10dp" />

                    <TextView
                        android:id="@+id/tv_release_date"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="2026-06-24"
                        android:textColor="@color/teks_sekunder"
                        android:textSize="12sp" />
                </LinearLayout>

                <!-- Trailer Action Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_trailer"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="20dp"
                    android:text="Watch Trailer"
                    android:textColor="@color/bg_utama"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    app:icon="@android:drawable/ic_media_play"
                    app:iconTint="@color/bg_utama"
                    app:cornerRadius="8dp"
                    app:backgroundTint="@color/aksen_amber" />

                <!-- Overview -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="Overview"
                    android:textColor="@color/teks_utama"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_overview"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Movie summary overview description..."
                    android:textColor="@color/teks_sekunder"
                    android:textSize="13sp"
                    android:lineSpacingExtra="5dp" />

                <!-- Cast and Crew -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="Cast &amp; Crew"
                    android:textColor="@color/teks_utama"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_cast"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    tools:listitem="@layout/item_cast" />

                <!-- Seasons & Episodes Section (Only visible for TV Shows / Anime) -->
                <LinearLayout
                    android:id="@+id/layout_seasons_episodes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone"
                    android:layout_marginTop="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Seasons &amp; Episodes"
                        android:textColor="@color/teks_utama"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <!-- Spinner Card Wrapper -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        app:cardCornerRadius="8dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="#2A2A3C"
                        app:cardBackgroundColor="@color/bg_surface">

                        <Spinner
                            android:id="@+id/spinner_seasons"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:paddingHorizontal="12dp"
                            android:popupBackground="@color/bg_surface" />
                    </com.google.android.material.card.MaterialCardView>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_episodes"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:nestedScrollingEnabled="false"
                        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                        tools:listitem="@layout/item_episode" />
                </LinearLayout>

            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Header Navigation Actions (Back / Watchlist Toggle) -->
    <ImageButton
        android:id="@+id/btn_back"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/circle_btn_bg"
        android:src="@android:drawable/ic_menu_revert"
        android:contentDescription="Back"
        app:tint="@color/teks_utama"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageButton
        android:id="@+id/btn_watchlist_toggle"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/circle_btn_bg"
        android:src="@drawable/ic_watchlist"
        android:contentDescription="Add to watchlist"
        app:tint="@color/teks_utama"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- See Reviews Button at the bottom -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_reviews"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_margin="16dp"
        android:text="See Reviews"
        android:textColor="@color/bg_utama"
        android:textSize="14sp"
        android:textStyle="bold"
        app:cornerRadius="12dp"
        app:backgroundTint="@color/aksen_amber"
        app:layout_constraintBottom_toBottomOf="parent" />

    <ProgressBar
        android:id="@+id/progress_bar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:indeterminateTint="@color/aksen_amber"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>
